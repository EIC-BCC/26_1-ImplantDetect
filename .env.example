# PostgreSQL
POSTGRES_DB=implantdetect
POSTGRES_USER=implantdetect_user
POSTGRES_PASSWORD=SUBSTITUA_POR_SENHA_FORTE

# API e prediction worker
# Deve usar o mesmo usuário/senha do PostgreSQL acima
DATABASE_URL=postgresql+asyncpg://implantdetect_user:SUBSTITUA_POR_SENHA_FORTE@postgres:5432/implantdetect

# RabbitMQ
RABBITMQ_USER=implantdetect
RABBITMQ_PASSWORD=SUBSTITUA_POR_SENHA_FORTE
RABBITMQ_URL=amqp://implantdetect:SUBSTITUA_POR_SENHA_FORTE@rabbitmq:5672/

# JWT — gerar com: openssl rand -hex 32
SECRET_KEY=SUBSTITUA_POR_SECRET_DE_256_BITS
