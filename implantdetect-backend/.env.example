ENVIRONMENT=development

# Gerar com: openssl rand -hex 32
SECRET_KEY=SUBSTITUA_POR_SECRET_DE_256_BITS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://root:SUBSTITUA_POR_SENHA_FORTE@postgres:5432/implantdetect
SQL_ECHO=false

# amqp://<user>:<password>@<host>:<port>/
RABBITMQ_URL=amqp://SUBSTITUA_POR_USUARIO:SUBSTITUA_POR_SENHA@rabbitmq:5672/

IMAGE_REPOSITORY=./uploads
UPLOAD_FILE_PATH=./uploads
IMAGE_MAXIMUM_SIZE=52428800
IMAGE_SUPPORTED_FORMATS=JPG,JPEG,PNG

YOLO_MODEL_PATH=./models/train/weights/best.pt

# Origens permitidas no CORS (separadas por vírgula, sem espaços)
CORS_ORIGINS=http://localhost:5173,http://localhost
