ENVIRONMENT=development

# Banco de dados (compartilhado com o backend)
DATABASE_URL=postgresql+asyncpg://root:password@postgres:5432/implantdetect
SQL_ECHO=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Modelo YOLO
YOLO_MODEL_PATH=../implantdetect-training/models/checkpoints/pipeline_completo_clahe_v8_small_200e/weights/best.pt

# Diretório de uploads (compartilhado com o backend)
UPLOAD_FILE_PATH=../implantdetect-backend/uploads
